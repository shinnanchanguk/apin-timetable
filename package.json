{
  "name": "apin-timetable",
  "version": "0.2.0",
  "description": "Unofficial client for the Apin (YWTek) school timetable server: dynamic app API + static file parser + cross-verification.",
  "type": "module",
  "license": "MIT",
  "author": "Shinchang Shin",
  "contributors": [
    "Shinchang Shin (shinnanchanguk)",
    "박준일 (pblsketch) — static file parser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shinnanchanguk/apin-timetable.git"
  },
  "bin": {
    "apin-timetable": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "live": "npm run build && node scripts/live-check.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "apin",
    "압핀",
    "timetable",
    "시간표",
    "ywtek",
    "sgpap",
    "school",
    "korea",
    "korean-school",
    "parser"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.8.3"
  }
}
